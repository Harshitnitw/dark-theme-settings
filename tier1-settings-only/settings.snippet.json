// =====================================================================
// Tier 1 — Safe / portable / survives updates
// =====================================================================
// Paste this into your IDE's user settings.json. It works in:
//   - Antigravity        (this is the primary target)
//   - VS Code            (replace "[Antigravity]" with "[Default Dark Modern]"
//                         or whatever theme you use)
//   - Cursor             ("[Cursor Dark]")
//   - VSCodium / Windsurf (same pattern)
//
// What you get out of Tier 1 alone:
//   • Black editor / sidebar / panel / titlebar / status bar
//   • Dim-gray (#7a7a7a) editor body — flat across body / bold /
//     heading in source view (no luminance hierarchy where size
//     and weight are uniform; preview adds the hierarchy)
//   • Dim active tab name (#8a8a8a) — fixes the bright tab filename
//   • Tab modified-dot indicator dimmed (no more bright white dot)
//   • Side bar section headers ("OUTLINE", "TIMELINE") dimmed
//   • Tree indent guides dimmed (file-tree vertical lines)
//   • Activity bar selected-item border + badge dimmed
//   • Lists: selection / focus / hover text color dimmed
//   • Editor text cursor + active-line highlight dimmed
//   • Bracket-pair guides + bracket-match highlight dimmed
//   • Autocomplete suggest widget + hover popups dimmed
//   • Command palette (Ctrl+Shift+P) + dropdowns + buttons dimmed
//   • Number badges + progress bar dimmed
//   • Status bar items (prominent / remote / error / warning) dimmed
//   • Notifications + notification links dimmed
//   • Git decoration colors (M/A/D in file tree) muted, still cued
//   • Command center (top URL-bar-like control) dimmed
//   • Terminal: ANSI colors dimmed but PRESERVED (Claude CLI / diffs
//     keep their semantic colors, just less bright)
//   • Terminal cursor dimmed
//   • Diff editor: muted green/red tints in editor + minimap
//
// What Tier 1 does NOT cover (need Tier 2/3 for these):
//   • Antigravity agent / Kilo Code chat panel (Tailwind-styled webview)
//   • Markdown PREVIEW (rendered HTML, not source)
//   • Bright text in agent confirmation widgets
//   • The orange "Update Available" pill in the top bar (Tailwind)
//
// =====================================================================

{
    "workbench.colorTheme": "Antigravity",
    "editor.fontSize": 18,
    "editor.wordWrap": "on",
    "files.autoSave": "afterDelay",

    // ─── integrated terminal bold/contrast rendering ────────────────────
    // Three settings work together so the dim ANSI palette below actually
    // looks dim. Without these, xterm.js silently undoes our dimming:
    //
    //  * fontWeightBold "normal": stops xterm.js from rendering bold tokens
    //    with a heavier font weight. The heavier strokes make text appear
    //    brighter regardless of color — defeats the dimmed ansiBrightWhite.
    //    With "normal", emphasis is signaled by COLOR alone (which is the
    //    anti-halation principle: emphasis = less luminance).
    //
    //  * drawBoldTextInBrightColors true (xterm.js default): routes ANSI
    //    bold through the bright palette. Combined with a dimmed
    //    terminal.ansiBrightWhite (#6a6a6a), this is how we make Claude
    //    Code's bold text (headings, "Update(...)", diff line counts, the
    //    ● bullet) dimmer than body (#7a7a7a) without breaking syntax
    //    color cues.
    //
    //  * minimumContrastRatio 1: disables xterm.js's auto-contrast lift.
    //    By default xterm.js silently brightens fg colors that fall below
    //    4.5:1 against bg — which would defeat any dim color we set here.
    //    Setting 1 (effectively off) keeps the palette exactly as authored.
    "terminal.integrated.fontWeightBold": "normal",
    "terminal.integrated.drawBoldTextInBrightColors": true,
    "terminal.integrated.minimumContrastRatio": 2.5,

    // NOTE: customizations are NOT theme-scoped ([ThemeName] wrappers).
    // Antigravity doesn't actually register a theme named "Antigravity" —
    // setting workbench.colorTheme to "Antigravity" silently falls back
    // to the default dark theme, so any "[Antigravity]" scope is dead
    // weight. Unscoped customizations apply regardless of active theme.
    //
    // For VS Code / Cursor users who DO have a real theme active, you
    // can optionally rewrap these in "[Default Dark Modern]" /
    // "[Cursor Dark]" if you want them to revert when switching themes.
    //
    // Source view is FLAT. No luminance hierarchy here — `# Heading`
    // and body prose are the same visual size in raw .md, so dimming
    // the heading would falsely shrink it. The anti-halation steps
    // (body → bold → h1/h2 each darker) only kick in in the markdown
    // PREVIEW, where size + weight actually grow. That's handled by
    // Tier 3's markdown.css patch, not here.
    //
    // We KEEP the markup.bold / markup.heading rules below (just
    // pinned to #7a7a7a, same as editor.foreground) so the underlying
    // theme can't paint them a different color. Diff hunks stay
    // muted blue.
    //
    // Editor syntax tokens. We dim the theme's bright syntax colors to
    // the SAME palette used for ANSI (red #a87a7a, green #7a9a7a, etc.)
    // so the editor and terminal stay luminance-coherent. Hue is
    // preserved — keywords still red, strings still green, types still
    // blue — but each color is luminance-matched to the dim ANSI set.
    //
    // Operators and punctuation are pinned at body color (#7a7a7a) so
    // dense glyph clusters (`::`, `<>`, `=>`) don't out-shout the
    // identifiers around them.
    //
    // Token rules stay scope-specific. Broad scopes like "text",
    // "source", or "text.html.markdown" would override all token
    // colors and flatten syntax highlighting (same mistake as
    // `body, body *` in CSS). The list below is narrow on purpose.
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": ["markup.bold", "markup.bold.markdown"],
                "settings": { "foreground": "#7a7a7a", "fontStyle": "" }
            },
            {
                "scope": ["markup.heading.markdown", "markup.heading"],
                "settings": { "foreground": "#7a7a7a", "fontStyle": "" }
            },
            {
                "scope": ["entity.name.section.markdown", "punctuation.definition.heading.markdown"],
                "settings": { "foreground": "#7a7a7a" }
            },
            {
                "scope": [
                    "meta.diff.header",
                    "meta.diff.index",
                    "meta.diff.header.from-file",
                    "meta.diff.header.to-file",
                    "meta.diff.range"
                ],
                "settings": { "foreground": "#5c758a" }
            },

            // ─── comments ─────────────────────────────────────────────
            // Dimmer than body so they sink into the background.
            {
                "scope": ["comment", "punctuation.definition.comment"],
                "settings": { "foreground": "#5a5a5a", "fontStyle": "italic" }
            },

            // ─── keywords ─────────────────────────────────────────────
            // Control flow (`if`, `else`, `return`, `for`, `while`, `match`)
            // → dim red. Other (`async`, `await`, `import`, `export`) too.
            {
                "scope": ["keyword", "keyword.control", "keyword.other"],
                "settings": { "foreground": "#a87a7a" }
            },
            // Operators (`=`, `::`, `=>`, `<`, `>`, `+`, `-`) → body color
            // so dense punctuation doesn't visually shout.
            {
                "scope": ["keyword.operator"],
                "settings": { "foreground": "#7a7a7a" }
            },

            // ─── storage (declaration words) ──────────────────────────
            // `let`, `const`, `var`, `fn`, `pub`, `mut`, `static`, `class`,
            // `def`, `function` → dim blue. They're declarators, not
            // control flow, so a separate hue from `keyword.control`.
            {
                "scope": ["storage", "storage.type", "storage.modifier"],
                "settings": { "foreground": "#5c758a" }
            },

            // ─── strings ──────────────────────────────────────────────
            {
                "scope": ["string", "string.quoted", "string.template"],
                "settings": { "foreground": "#7a9a7a" }
            },
            // String escapes (`\n`, `\t`) → dim yellow so they're
            // distinguishable inside green string runs.
            {
                "scope": ["constant.character.escape", "string.regexp"],
                "settings": { "foreground": "#8a8270" }
            },

            // ─── numbers / language constants ─────────────────────────
            // `42`, `3.14`, `0xff`, `true`, `false`, `null`, `None`,
            // `Some`, `nil`, `undefined` → dim yellow.
            {
                "scope": ["constant.numeric", "constant.language"],
                "settings": { "foreground": "#8a8270" }
            },

            // ─── functions & methods ──────────────────────────────────
            // Definition + call sites → dim cyan. `support.function`
            // catches builtins (`println!`, `print`, `console.log`).
            {
                "scope": [
                    "entity.name.function",
                    "meta.function-call",
                    "support.function",
                    "variable.function"
                ],
                "settings": { "foreground": "#5c8a8a" }
            },

            // ─── types, classes, enums, interfaces ────────────────────
            // `Result`, `Scalar`, `Vec`, `String`, `i32`, `Witness`,
            // `MyClass`, `MyInterface` → dim blue (same as storage so
            // type system tokens group together visually).
            {
                "scope": [
                    "entity.name.type",
                    "entity.name.class",
                    "entity.name.enum",
                    "entity.name.interface",
                    "entity.name.struct",
                    "entity.name.namespace",
                    "support.type",
                    "support.class",
                    "support.type.primitive"
                ],
                "settings": { "foreground": "#5c758a" }
            },

            // ─── constants (UPPER_CASE) ───────────────────────────────
            {
                "scope": ["variable.other.constant", "constant.other"],
                "settings": { "foreground": "#8a8270" }
            },

            // ─── variables / parameters / properties ──────────────────
            // Body color — identifiers are the most common tokens, so
            // they sit at the editor's base luminance and the colored
            // tokens above stand out against them.
            {
                "scope": [
                    "variable",
                    "variable.other",
                    "variable.parameter",
                    "variable.other.readwrite",
                    "variable.other.property",
                    "meta.object-literal.key"
                ],
                "settings": { "foreground": "#7a7a7a" }
            },

            // ─── punctuation ──────────────────────────────────────────
            // `{`, `}`, `(`, `)`, `;`, `,`, `.` → body color. Some themes
            // paint brackets bright; we pin them so they don't stand out.
            {
                "scope": [
                    "punctuation",
                    "punctuation.separator",
                    "punctuation.terminator",
                    "punctuation.section",
                    "meta.brace"
                ],
                "settings": { "foreground": "#7a7a7a" }
            },

            // ─── decorators / attributes / annotations ────────────────
            // `@override`, `#[derive(...)]`, `@app.route(...)` → dim
            // magenta so they're visually distinct from regular calls.
            {
                "scope": [
                    "entity.name.decorator",
                    "meta.decorator",
                    "meta.annotation",
                    "meta.attribute",
                    "punctuation.definition.annotation"
                ],
                "settings": { "foreground": "#7a5c8a" }
            },

            // ─── tags (HTML/JSX/XML) ──────────────────────────────────
            {
                "scope": ["entity.name.tag", "meta.tag"],
                "settings": { "foreground": "#a87a7a" }
            },
            {
                "scope": ["entity.other.attribute-name"],
                "settings": { "foreground": "#8a8270" }
            },

            // ─── invalid / deprecated ─────────────────────────────────
            // Theme defaults paint these in alarming reds — keep them
            // signaling but at the same dim red as keywords.
            {
                "scope": ["invalid", "invalid.deprecated"],
                "settings": { "foreground": "#a87a7a", "fontStyle": "italic" }
            }
        ]
    },

    "workbench.colorCustomizations": {
            // ─── base ─────────────────────────────────────────────────
            "foreground": "#969696",
            "widget.foreground": "#969696",
            "descriptionForeground": "#969696",

            // ─── editor ───────────────────────────────────────────────
            "editor.foreground": "#7a7a7a",
            "editor.background": "#000000",
            "editor.selectionBackground": "#1a1a1a",
            "editorGroup.background": "#000000",
            "editorGroupHeader.tabsBackground": "#000000",
            "editorGroupHeader.noTabsBackground": "#000000",
            "editorGroupHeader.tabsBorder": "#0a0a0a",
            "editorLineNumber.foreground": "#333333",
            "editorLineNumber.activeForeground": "#555555",
            "editorIndentGuide.background1": "#111111",
            "editorIndentGuide.activeBackground1": "#2a2a2a",
            "editorWidget.background": "#000000",
            "editorWidget.border": "#1a1a1a",
            "editorOverviewRuler.border": "#000000",
            "editorOverviewRuler.addedForeground": "#5c7a5c",
            "editorOverviewRuler.deletedForeground": "#7a5c5c",
            "editorOverviewRuler.modifiedForeground": "#7a735c",
            "editorGutter.addedBackground": "#5c7a5c",
            "editorGutter.deletedBackground": "#7a5c5c",
            "editorGutter.modifiedBackground": "#7a735c",

            // ─── tabs (fixes bright active tab from screenshot) ───────
            "tab.activeForeground": "#8a8a8a",
            "tab.activeBackground": "#000000",
            "tab.inactiveForeground": "#444444",
            "tab.inactiveBackground": "#000000",
            "tab.border": "#0a0a0a",
            "tab.activeBorder": "#555555",
            "tab.activeBorderTop": "#555555",
            "tab.hoverForeground": "#8a8a8a",
            "tab.unfocusedActiveForeground": "#555555",
            "tab.unfocusedActiveBorder": "#555555",

            // ─── sidebar / activity bar / title bar / status bar ──────
            "sideBar.foreground": "#969696",
            "sideBarTitle.foreground": "#969696",
            "sideBar.background": "#000000",
            "sideBarSectionHeader.background": "#000000",
            "activityBar.foreground": "#969696",
            "activityBar.background": "#000000",
            "activityBar.inactiveForeground": "#444444",
            "titleBar.activeForeground": "#969696",
            "titleBar.activeBackground": "#000000",
            "titleBar.inactiveForeground": "#555555",
            "titleBar.inactiveBackground": "#000000",
            "statusBar.foreground": "#969696",
            "statusBar.background": "#000000",
            "statusBar.noFolderBackground": "#000000",

            // ─── panel ────────────────────────────────────────────────
            "panel.foreground": "#969696",
            "panel.background": "#000000",
            "panel.border": "#0a0a0a",
            "panelTitle.activeForeground": "#969696",
            "panelTitle.inactiveForeground": "#555555",

            // ─── breadcrumb / lists / scrollbar / minimap ─────────────
            "breadcrumb.foreground": "#555555",
            "breadcrumb.focusForeground": "#969696",
            "breadcrumb.activeSelectionForeground": "#969696",
            "list.hoverBackground": "#0a0a0a",
            "list.activeSelectionBackground": "#1a1a1a",
            "list.inactiveSelectionBackground": "#0d0d0d",
            "scrollbar.shadow": "#000000",
            "scrollbarSlider.background": "#1a1a1a",
            "scrollbarSlider.hoverBackground": "#2a2a2a",
            "scrollbarSlider.activeBackground": "#3a3a3a",
            "minimap.background": "#000000",

            // ─── inputs / chat input ──────────────────────────────────
            "input.foreground": "#969696",
            "input.background": "#000000",
            "input.border": "#1a1a1a",
            "input.placeholderForeground": "#555555",
            "chat.requestForeground": "#969696",

            // ─── text styling primitives ──────────────────────────────
            "textPreformat.foreground": "#969696",
            "textLink.foreground": "#5c758a",
            "textLink.activeForeground": "#6b86a1",
            "textBlockQuote.background": "#050505",
            "textBlockQuote.border": "#1a1a1a",

            // ─── menus / icons / notifications ────────────────────────
            "icon.foreground": "#555555",
            "menu.foreground": "#969696",
            "menu.background": "#000000",
            "notificationCenterHeader.background": "#000000",
            "notifications.background": "#0a0a0a",
            "notification.foreground": "#969696",
            "debugToolBar.background": "#000000",
            "peekViewResult.background": "#000000",
            "peekViewEditor.background": "#000000",
            "peekViewTitle.background": "#000000",

            // ─── TERMINAL — KEEP COLORS, JUST DIM THEM ────────────────
            // This is the critical block for the Claude Code / Kilo CLI
            // brightness complaint. We dim white→#969696 so it stops
            // hurting your eyes, but we leave the other ANSI colors
            // as muted versions of themselves so syntax / diff / status
            // colors are still distinguishable.
            "terminal.foreground": "#7a7a7a",
            "terminal.background": "#000000",
            "terminal.selectionBackground": "#1a1a1a",
            // ansiBrightBlack is what Claude Code (and many TUIs) use as
            // the user-input panel / "subtle highlight" background. The
            // xterm default is ~#808080 which halates badly on pure black.
            "terminal.ansiBlack": "#000000",
            "terminal.ansiBrightBlack": "#1a1a1a",
            // VS Code's terminal renders ANSI bold by mapping to the bright
            // color variant (drawBoldTextInBrightColors=true by default).
            // Claude Code emits bold for headings, line counts (`9`, `31`),
            // emphasis words (`both`), and the `●` bullet — all routed
            // through ansiBrightWhite. Per anti-halation: bold should be
            // DIMMER than body, not equal/brighter. So ansiBrightWhite is
            // explicitly DIMMER than ansiWhite.
            "terminal.ansiBrightWhite": "#6a6a6a",
            "terminal.ansiWhite": "#7a7a7a",
            // Red and green are tuned for diff readability in Claude Code:
            // removed lines (ansiRed) and added lines (ansiGreen) need to
            // be DIM enough to avoid halation but BRIGHT enough that the
            // text inside them is readable. #7a5c5c / #5c7a5c (the prior
            // values) were unreadable on black — bumped to these levels.
            "terminal.ansiBrightGreen": "#7a9a7a",
            "terminal.ansiGreen": "#7a9a7a",
            "terminal.ansiBrightRed": "#a87a7a",
            "terminal.ansiRed": "#a87a7a",
            "terminal.ansiBrightYellow": "#8a8270",
            "terminal.ansiYellow": "#8a8270",
            "terminal.ansiBrightBlue": "#5c758a",
            "terminal.ansiBlue": "#5c758a",
            "terminal.ansiBrightCyan": "#5c8a8a",
            "terminal.ansiCyan": "#5c8a8a",
            "terminal.ansiBrightMagenta": "#7a5c8a",
            "terminal.ansiMagenta": "#7a5c8a",
            "terminalCursor.foreground": "#5a5a5a",
            "terminalCursor.background": "#000000",

            // ─── diff editor ──────────────────────────────────────────
            "diffEditor.insertedTextBackground": "#1a2a1a40",
            "diffEditor.removedTextBackground": "#2a1a1a40",
            "diffEditor.insertedLineBackground": "#0a150a60",
            "diffEditor.removedLineBackground": "#150a0a60",
            "diffEditor.border": "#1a1a1a",
            "diffEditorGutter.insertedLineBackground": "#0a150a",
            "diffEditorGutter.removedLineBackground": "#150a0a",
            "diffEditorOverview.insertedForeground": "#5c7a5c",
            "diffEditorOverview.removedForeground": "#7a5c5c",

            // ─── side bar — section labels ("OUTLINE", "TIMELINE") ────
            "sideBarSectionHeader.foreground": "#8a8a8a",
            "sideBarSectionHeader.border": "#0a0a0a",
            "sideBar.border": "#0a0a0a",
            "tree.indentGuidesStroke": "#1a1a1a",
            "tree.inactiveIndentGuidesStroke": "#111111",
            "tree.tableColumnsBorder": "#1a1a1a",

            // ─── activity bar — left-edge indicator + badges ──────────
            "activityBar.activeBorder": "#555555",
            "activityBar.activeBackground": "#0a0a0a",
            "activityBar.activeFocusBorder": "#555555",
            "activityBar.border": "#0a0a0a",
            "activityBarBadge.background": "#1a1a1a",
            "activityBarBadge.foreground": "#969696",

            // ─── list text colors (selection / focus / hover) ─────────
            "list.activeSelectionForeground": "#969696",
            "list.inactiveSelectionForeground": "#969696",
            "list.focusForeground": "#969696",
            "list.hoverForeground": "#969696",
            "list.highlightForeground": "#8a8a8a",
            "list.focusHighlightForeground": "#8a8a8a",
            "list.errorForeground": "#7a5c5c",
            "list.warningForeground": "#7a735c",
            "list.deemphasizedForeground": "#555555",

            // ─── tab modified-dot indicator ───────────────────────────
            "tab.activeModifiedBorder": "#555555",
            "tab.inactiveModifiedBorder": "#444444",
            "tab.unfocusedActiveModifiedBorder": "#333333",
            "tab.unfocusedInactiveModifiedBorder": "#222222",

            // ─── editor inner widgets ─────────────────────────────────
            "editorCursor.foreground": "#969696",
            // Ghost text / inline AI suggestions — Antigravity defaults
            // editorGhostText.border to a bright blue I-beam that ignores
            // the rest of the palette. Force foreground dim + background
            // and border transparent so the suggestion blends into the
            // editor instead of stamping a blue bar at the cursor.
            "editorGhostText.foreground": "#5a5a5a",
            "editorGhostText.background": "#00000000",
            "editorGhostText.border": "#00000000",
            "editor.lineHighlightBackground": "#0a0a0a",
            "editor.lineHighlightBorder": "#0a0a0a",
            "editorBracketMatch.background": "#1a1a1a",
            "editorBracketMatch.border": "#2a2a2a",
            "editor.findMatchBackground": "#3a3a1a",
            "editor.findMatchHighlightBackground": "#2a2a1a",
            "editor.findRangeHighlightBackground": "#1a1a1a",
            "editor.wordHighlightBackground": "#1a1a1a",
            "editor.wordHighlightStrongBackground": "#2a2a2a",
            "editor.selectionHighlightBackground": "#1a1a1a",
            "editorBracketPairGuide.background1": "#1a1a1a",
            "editorBracketPairGuide.background2": "#1a1a1a",
            "editorBracketPairGuide.background3": "#1a1a1a",
            "editorBracketPairGuide.background4": "#1a1a1a",
            "editorBracketPairGuide.background5": "#1a1a1a",
            "editorBracketPairGuide.background6": "#1a1a1a",
            "editorBracketPairGuide.activeBackground1": "#2a2a2a",
            "editorBracketPairGuide.activeBackground2": "#2a2a2a",
            "editorBracketPairGuide.activeBackground3": "#2a2a2a",
            "editorBracketPairGuide.activeBackground4": "#2a2a2a",
            "editorBracketPairGuide.activeBackground5": "#2a2a2a",
            "editorBracketPairGuide.activeBackground6": "#2a2a2a",
            "editorGroup.border": "#0a0a0a",
            "editorWidget.foreground": "#969696",
            "editorRuler.foreground": "#1a1a1a",
            "editorOverviewRuler.findMatchForeground": "#3a3a1a",
            "editorOverviewRuler.selectionHighlightForeground": "#2a2a2a",
            "editorOverviewRuler.wordHighlightForeground": "#2a2a2a",

            // ─── autocomplete / hover / command palette ───────────────
            "editorSuggestWidget.background": "#000000",
            "editorSuggestWidget.foreground": "#969696",
            "editorSuggestWidget.border": "#1a1a1a",
            "editorSuggestWidget.selectedBackground": "#1a1a1a",
            "editorSuggestWidget.selectedForeground": "#969696",
            "editorSuggestWidget.highlightForeground": "#8a8a8a",
            "editorSuggestWidget.focusHighlightForeground": "#8a8a8a",
            "editorHoverWidget.background": "#000000",
            "editorHoverWidget.foreground": "#969696",
            "editorHoverWidget.border": "#1a1a1a",
            "editorHoverWidget.statusBarBackground": "#000000",
            "quickInput.background": "#000000",
            "quickInput.foreground": "#969696",
            "quickInputList.focusBackground": "#1a1a1a",
            "quickInputList.focusForeground": "#969696",
            "quickInputList.focusIconForeground": "#8a8a8a",
            "quickInputTitle.background": "#000000",
            "pickerGroup.foreground": "#555555",
            "pickerGroup.border": "#1a1a1a",

            // ─── dropdowns / buttons / badges / progress ──────────────
            "dropdown.background": "#000000",
            "dropdown.foreground": "#969696",
            "dropdown.border": "#1a1a1a",
            "dropdown.listBackground": "#000000",
            "button.background": "#1a1a1a",
            "button.foreground": "#969696",
            "button.hoverBackground": "#2a2a2a",
            "button.border": "#1a1a1a",
            "button.secondaryBackground": "#0a0a0a",
            "button.secondaryForeground": "#969696",
            "button.secondaryHoverBackground": "#1a1a1a",
            "badge.background": "#1a1a1a",
            "badge.foreground": "#969696",
            "progressBar.background": "#555555",

            // ─── status bar items (extends statusBar.foreground) ──────
            "statusBarItem.foreground": "#969696",
            "statusBarItem.hoverBackground": "#1a1a1a",
            "statusBarItem.activeBackground": "#2a2a2a",
            "statusBarItem.prominentForeground": "#969696",
            "statusBarItem.prominentBackground": "#1a1a1a",
            "statusBarItem.prominentHoverBackground": "#2a2a2a",
            "statusBarItem.remoteForeground": "#969696",
            "statusBarItem.remoteBackground": "#1a1a1a",
            "statusBarItem.errorForeground": "#7a5c5c",
            "statusBarItem.errorBackground": "#150a0a",
            "statusBarItem.warningForeground": "#7a735c",
            "statusBarItem.warningBackground": "#15110a",

            // ─── notifications ────────────────────────────────────────
            "notifications.foreground": "#969696",
