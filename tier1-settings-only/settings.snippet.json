            "notificationLink.foreground": "#5c758a",
            "notificationToast.border": "#1a1a1a",
            "notificationsErrorIcon.foreground": "#7a5c5c",
            "notificationsWarningIcon.foreground": "#7a735c",
            "notificationsInfoIcon.foreground": "#5c758a",

            // ─── git decorations (file tree M/A/D color cues) ─────────
            "gitDecoration.modifiedResourceForeground": "#7a735c",
            "gitDecoration.addedResourceForeground": "#5c7a5c",
            "gitDecoration.deletedResourceForeground": "#7a5c5c",
            "gitDecoration.untrackedResourceForeground": "#5c7a5c",
            "gitDecoration.ignoredResourceForeground": "#444444",
            "gitDecoration.conflictingResourceForeground": "#7a735c",
            "gitDecoration.submoduleResourceForeground": "#5c758a",
            "gitDecoration.stageModifiedResourceForeground": "#7a735c",
            "gitDecoration.stageDeletedResourceForeground": "#7a5c5c",
            "gitDecoration.renamedResourceForeground": "#5c758a",

            // ─── command center (top-bar URL-bar-like control) ────────
            "commandCenter.background": "#0a0a0a",
            "commandCenter.foreground": "#969696",
            "commandCenter.activeBackground": "#1a1a1a",
            "commandCenter.activeForeground": "#969696",
            "commandCenter.border": "#1a1a1a",
            "commandCenter.activeBorder": "#2a2a2a",

            // ─── input validation popups ──────────────────────────────
            "inputValidation.errorBackground": "#150a0a",
            "inputValidation.errorForeground": "#7a5c5c",
            "inputValidation.errorBorder": "#7a5c5c",
            "inputValidation.warningBackground": "#15110a",
            "inputValidation.warningForeground": "#7a735c",
            "inputValidation.warningBorder": "#7a735c",
            "inputValidation.infoBackground": "#0a1015",
            "inputValidation.infoForeground": "#5c758a",
            "inputValidation.infoBorder": "#5c758a"
    }
}
